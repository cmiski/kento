NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_hub?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=info
NOTIFICATION_DELIVERY_TIMEOUT_MS=5000
USER_RATE_LIMIT_WINDOW_SECONDS=60
USER_RATE_LIMIT_MAX_REQUESTS=120
PRESENCE_TTL_SECONDS=120
DELIVERY_QUEUE_POLL_MS=250
DELIVERY_QUEUE_RECOVERY_MS=30000
DELIVERY_QUEUE_RECOVERY_BATCH=1000
DELIVERY_JOB_LEASE_MS=60000
DELIVERY_RETRY_BASE_MS=1000
DELIVERY_THROTTLE_PER_MINUTE=60
